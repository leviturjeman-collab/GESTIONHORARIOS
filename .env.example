# ─────────────────────────────────────────────────────────────
# Gestión Horarios — variables de entorno
# Copia este archivo a `.env` y rellena los valores.
# ─────────────────────────────────────────────────────────────

# Base de datos.
#  - Desarrollo (SQLite):  file:./dev.db
#  - Producción (PostgreSQL):  postgresql://USER:PASS@HOST:5432/gestion_horarios?schema=public
DATABASE_URL="file:./dev.db"

# Auth.js / NextAuth.
# Genera un secreto con:  openssl rand -base64 32   (o:  npx auth secret)
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Anthropic (Claude) — análisis de Excel, generación de cuadrantes, detección de
# problemas y asistente. Si se deja vacío, la IA funciona en MODO SIMULADO
# (respuestas deterministas locales) para poder desarrollar sin clave.
ANTHROPIC_API_KEY=""
# Modelo por defecto (generación y asistente).
ANTHROPIC_MODEL="claude-opus-4-8"
# Modelos por operación (opcional). Recomendado: Haiku para análisis simples,
# Sonnet para generación. Si se dejan vacíos, ANALISIS/DETECCION usan Haiku y
# GENERACION/ASISTENTE usan ANTHROPIC_MODEL.
ANTHROPIC_MODEL_ANALISIS="claude-haiku-4-5"
ANTHROPIC_MODEL_GENERACION="claude-sonnet-4-6"

# Google AI (Gemini) — OCR de imágenes (fotos/capturas de cuadrantes) y PDFs
# escaneados. Capa gratuita en Google AI Studio (sin coste para bajo volumen).
# Consigue la clave en https://aistudio.google.com/apikey (empieza por "AIza").
GOOGLE_AI_KEY=""
# Modelo de Gemini para el OCR (opcional). Por defecto: gemini-3.5-flash.
# Cámbialo aquí si Google retira/renombra el modelo, sin tocar el código.
GOOGLE_OCR_MODEL="gemini-3.5-flash"

# Correo saliente (Resend). Si se deja vacío, los correos se registran por consola.
RESEND_API_KEY=""
EMAIL_FROM="Gestión Horarios <onboarding@resend.dev>"

# URL pública de la aplicación (usada en los enlaces de los correos).
APP_URL="http://localhost:3000"
